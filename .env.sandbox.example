# Sandbox (ex.: https://sbx.visitaai.cloud) — mesma forma que produção/demo; DB separada.
# Coolify: novo recurso app + MySQL (ou novo schema), APP_KEY próprio, secrets próprios.

APP_URL=https://sbx.visitaai.cloud
APP_INSTANCE_TYPE=demo
SESSION_DOMAIN=.visitaai.cloud

APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_BRAND="Visita Aí"
APP_NAME=
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12
APP_TRUSTED_PROXIES=*
APP_FORCE_HTTPS=

SECURITY_CSP=true
SECURITY_HSTS=
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_SUBDOMAINS=false
SECURITY_HSTS_PRELOAD=false

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=visita_ai_sbx
DB_USERNAME=visita
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_BRAND}"

VITE_APP_NAME="Visita Aí"
