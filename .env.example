# Configurações básicas
APP_NAME="Visita Aí - Sistema de Visitas Epidemiológicas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Localização
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

# Manutenção
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

# Segurança
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco de dados
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=visita_ai
DB_USERNAME=visita
DB_PASSWORD=

# Sessão
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Filesystem
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Cache
CACHE_STORE=file

# E-mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME="bitwiseoficial@gmail.com"
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="bitwiseoficial@gmail.com"
MAIL_FROM_NAME="${APP_NAME} - Sistema de Visitas Epidemiológicas"

# Frontend
VITE_APP_NAME="${APP_NAME} - Sistema de Visitas Epidemiológicas"
