# Configurações básicas (em produção use APP_ENV=production e APP_DEBUG=false)
APP_NAME="Visita Aí - Sistema de Visitas Epidemiológicas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Atrás de nginx/load balancer/Cloudflare: use APP_TRUSTED_PROXIES=* ou lista de IPs
APP_TRUSTED_PROXIES=*

# Content-Security-Policy: SECURITY_CSP=false para desativar o header
SECURITY_CSP=true

# Localização
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

# Manutenção
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

# Segurança
BCRYPT_ROUNDS=12

# Logging (em produção prefira LOG_LEVEL=warning ou error)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco de dados (Docker: serviço "db", fora do Docker use 127.0.0.1 e porta 3307 se mapeada)
# DB_PASSWORD é usada pela aplicação e pelo docker-compose (MYSQL_PASSWORD). Defina uma senha forte e não commite o .env.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=visita_ai
DB_USERNAME=visita
DB_PASSWORD=

# Sessão (em produção use SESSION_SECURE_COOKIE=true e HTTPS)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Filesystem
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Cache
CACHE_STORE=file

# E-mail (envio de links de redefinição de senha, etc.)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@exemplo.com"
MAIL_FROM_NAME="${APP_NAME}"

# Frontend
VITE_APP_NAME="${APP_NAME} - Sistema de Visitas Epidemiológicas"
