# =============================================================================
# Coolify / PaaS / Docker Compose — o que é DINÂMICO (injetar no deploy, não commitar)
# =============================================================================
#
# Defina no painel (Secrets + Environment + Domains), não ficheiros no Git:
#
# • APP_URL ………….……… URL pública HTTPS deste serviço (= domínio principal em Coolify → Domains).
# • APP_KEY ………….……… php artisan key:generate --show (Secret no Coolify).
# • DB_* ………………….…… credenciais da base (host interno rede Docker, ex. db:3306).
# • MAIL_* ………………… SMTP (Secrets).
# • REGISTRY_* / TENANT_* … só se usar multi-tenant no mesmo processo (opcional; produção típica = uma instância Coolify por cliente, tudo false/vazio — ver README).
#
# Pode REMOVER do .env da aplicação (não são lidos pelo Laravel — eram só nota humana):
# • SERVICE_URL_WEB, SERVICE_FQDN_WEB
#
# Estas pertencem ao SERVIÇO MySQL no Coolify/Compose, NÃO ao contentor PHP (remover do .env da app):
# • MYSQL_ROOT_PASSWORD, MYSQL_HOST_PORT, ou outras MYSQL_* só para o container db
#
# Evite APP_NAME vazio com MAIL_FROM_NAME=${APP_NAME}: use APP_BRAND e MAIL_FROM_NAME fixo ou =APP_BRAND.
#
# =============================================================================
# Modelo instância (ajuste valores; demo em subdomain típico: APP_URL=https://demo.example.com)
# =============================================================================
APP_URL=https://visitaai.cloud
APP_INSTANCE_TYPE=base
SESSION_DOMAIN=.visitaai.cloud
# (opcional, legado — o código NÃO usa estas variáveis)
# SERVICE_URL_WEB=https://visitaai.cloud
# SERVICE_FQDN_WEB=visitaai.cloud

# App
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Marca curta (hero, título curto); se definir, pode usar MAIL_FROM_NAME="${APP_BRAND}"
APP_BRAND=Visita Aí
# Idioma da interface: pt_BR (padrão) ou en — ficheiros em lang/pt_BR.json e lang/en.json
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

# Manutenção e segurança
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12
APP_TRUSTED_PROXIES=*
# Forçar URLs https (além do auto-detect em produção quando APP_URL é https)
APP_FORCE_HTTPS=

# Cabeçalhos de segurança
SECURITY_CSP=true
# HSTS: ativo por defeito em APP_ENV=production; desative com SECURITY_HSTS=false em HTTP local
SECURITY_HSTS=
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_SUBDOMAINS=false
SECURITY_HSTS_PRELOAD=false

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# -----------------------------------------------------------------------------
# Registry de tenants (opcional): um deploy PHP a servir vários subdomínios/bases.
# Produção recomendada: uma app Coolify por cliente — manter false e vazio abaixo.
# Migração registry: php artisan registry:migrate  |  Ver docs/MULTI-TENANT-SUBDOMINIO-DESIGN.md
# -----------------------------------------------------------------------------
TENANT_REGISTRY_ENABLED=false
REGISTRY_DB_DATABASE=
# REGISTRY_DB_HOST=    # omite para reutilizar DB_HOST
# REGISTRY_DB_USERNAME=
# REGISTRY_DB_PASSWORD=
# Domínios base (FQDN), separados por vírgula — ex.: visitaai.cloud
TENANT_REGISTRY_BASE_DOMAINS=
# Em localhost: força o slug (ex.: demo) quando TENANT_REGISTRY_ENABLED=true
TENANT_DEV_SLUG=
TENANT_REGISTRY_FORCE_ROOT_URL=true
# Agendar tenants:migrate --force diariamente (scheduler Laravel + cron no servidor)
TENANT_REGISTRY_SCHEDULE_MIGRATE=false
# E-mails (use_email) com acesso a /system/tenant-registry (lista separada por vírgulas)
REGISTRY_ADMIN_EMAILS=
#
# Provisionar novo município: criar schema MySQL + migrate + linha no registry
# (artisan tenants:provision {slug} ou checkbox no formulário "Novo tenant")
# TENANT_PROVISION_ENABLED=false
# TENANT_DATABASE_PREFIX=visita_
# Credenciais com CREATE DATABASE (se DB_USERNAME da app não tiver):
# TENANT_PROVISION_DB_USERNAME=root
# TENANT_PROVISION_DB_PASSWORD=
# Opcional: utilizador da app que deve receber GRANT na nova base
# TENANT_PROVISION_GRANT_APP_USERNAME=visita
# TENANT_PROVISION_GRANT_APP_HOST=%
#
# Ativar de seguida após TENANT_REGISTRY_* (entrypoint corre tenant-registry:bootstrap):
# true = cria/atualiza 1 tenant. Pode usar a MESMA base que DB_DATABASE (REGISTRY_DB_DATABASE=visita_ai).
# Se TENANT_PROVISION_ENABLED=true e a base do bootstrap for outra que a do registry, cria schema + migrate.
TENANT_REGISTRY_BOOTSTRAP=false
TENANT_REGISTRY_BOOTSTRAP_SLUG=demo
# omite para usar DB_DATABASE
# TENANT_REGISTRY_BOOTSTRAP_DATABASE=
# TENANT_REGISTRY_BOOTSTRAP_ENV=production
# TENANT_REGISTRY_BOOTSTRAP_DISPLAY_NAME=
# TENANT_REGISTRY_BOOTSTRAP_BRAND=

# Banco de dados
DB_CONNECTION=mysql
# Em Docker (app + db na mesma rede, ex. Coolify): db. PHP no host com docker compose só do MySQL abaixo: 127.0.0.1
DB_HOST=db
DB_PORT=3306
DB_DATABASE=visita_ai
DB_USERNAME=visita
DB_PASSWORD=

# Sessão
# file = recomendado em Docker. database = exige migração create_sessions_table e tabela sessions.
SESSION_DRIVER=file
SESSION_LIFETIME=120
# true = payload da sessão encriptado (recomendado em produção com driver file/database)
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Filesystem e cache
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# E-mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
# Remetente visível (evitar ${APP_NAME} se APP_NAME estiver vazio; usar texto fixo ou ${APP_BRAND})
MAIL_FROM_NAME="${APP_BRAND}"

# Frontend (baked no build)
VITE_APP_NAME=
